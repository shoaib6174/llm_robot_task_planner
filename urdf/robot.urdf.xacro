<?xml version="1.0" encoding="utf-8"?>
<robot name="jetrover" xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- Include JetRover description files (mecanum chassis + A1 lidar) -->
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/materials.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/inertial_matrix.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/car_mecanum.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/lidar.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/lidar_a1.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/imu.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/depth_camera.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/common.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/connect.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/arm.urdf.xacro"/>
    <xacro:include filename="$(find llm_robot_task_planner)/urdf/jetrover_description/urdf/gripper.urdf.xacro"/>

    <!-- ==================== Fixed Body Camera (for perception scanning) ==================== -->
    <!-- Front-facing RGBD camera on robot body, tilted 30° down to see floor/cubes -->
    <link name="body_cam_link">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
    </link>
    <joint name="body_cam_joint" type="fixed">
        <!-- Mounted at front-top of base_link, tilted 20° down (pitch = 0.35 rad) -->
        <origin xyz="0.12 0.0 0.06" rpy="0 0.35 0"/>
        <parent link="base_link"/>
        <child link="body_cam_link"/>
    </joint>
    <!-- Optical frame (standard: z-forward, x-right, y-down) -->
    <link name="body_cam_optical_frame"/>
    <joint name="body_cam_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
        <parent link="body_cam_link"/>
        <child link="body_cam_optical_frame"/>
    </joint>

    <!-- ==================== Gazebo Plugins ==================== -->

    <!-- Diff drive (simpler than mecanum for initial testing, upgrade later) -->
    <!-- Wheel geometry: separation=0.2242m, radius~0.048m -->
    <gazebo>
        <plugin filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
            <left_joint>wheel_left_front_joint</left_joint>
            <left_joint>wheel_left_back_joint</left_joint>
            <right_joint>wheel_right_front_joint</right_joint>
            <right_joint>wheel_right_back_joint</right_joint>
            <wheel_separation>0.2242</wheel_separation>
            <wheel_radius>0.048</wheel_radius>
            <odom_publish_frequency>50</odom_publish_frequency>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <max_linear_acceleration>1.0</max_linear_acceleration>
            <max_angular_acceleration>2.0</max_angular_acceleration>
        </plugin>
    </gazebo>

    <!-- Joint state publisher (publishes wheel joint states) -->
    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher">
            <joint_name>wheel_left_front_joint</joint_name>
            <joint_name>wheel_left_back_joint</joint_name>
            <joint_name>wheel_right_front_joint</joint_name>
            <joint_name>wheel_right_back_joint</joint_name>
            <joint_name>joint1</joint_name>
            <joint_name>joint2</joint_name>
            <joint_name>joint3</joint_name>
            <joint_name>joint4</joint_name>
            <joint_name>joint5</joint_name>
            <joint_name>r_joint</joint_name>
        </plugin>
    </gazebo>

    <!-- ==================== Arm Joint Controllers ==================== -->
    <!-- PID controllers for arm joints. Damping reduced to 2.0 so these
         moderate gains can easily control the joints. No I gain to avoid windup. -->
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>joint1</joint_name>
            <topic>arm/joint1/cmd_pos</topic>
            <p_gain>200</p_gain>
            <i_gain>0</i_gain>
            <d_gain>20</d_gain>
            <cmd_max>50</cmd_max>
            <cmd_min>-50</cmd_min>
        </plugin>
    </gazebo>
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>joint2</joint_name>
            <topic>arm/joint2/cmd_pos</topic>
            <p_gain>200</p_gain>
            <i_gain>0</i_gain>
            <d_gain>20</d_gain>
            <cmd_max>50</cmd_max>
            <cmd_min>-50</cmd_min>
        </plugin>
    </gazebo>
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>joint3</joint_name>
            <topic>arm/joint3/cmd_pos</topic>
            <p_gain>200</p_gain>
            <i_gain>0</i_gain>
            <d_gain>20</d_gain>
            <cmd_max>50</cmd_max>
            <cmd_min>-50</cmd_min>
        </plugin>
    </gazebo>
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>joint4</joint_name>
            <topic>arm/joint4/cmd_pos</topic>
            <p_gain>200</p_gain>
            <i_gain>0</i_gain>
            <d_gain>20</d_gain>
            <cmd_max>50</cmd_max>
            <cmd_min>-50</cmd_min>
        </plugin>
    </gazebo>
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>joint5</joint_name>
            <topic>arm/joint5/cmd_pos</topic>
            <p_gain>100</p_gain>
            <i_gain>0</i_gain>
            <d_gain>10</d_gain>
            <cmd_max>20</cmd_max>
            <cmd_min>-20</cmd_min>
        </plugin>
    </gazebo>

    <!-- ==================== Gripper Controller ==================== -->
    <!-- Only r_joint is actuated; l_joint and all linkage joints mimic it -->
    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>r_joint</joint_name>
            <topic>arm/gripper/cmd_pos</topic>
            <p_gain>50</p_gain>
            <i_gain>0</i_gain>
            <d_gain>5</d_gain>
            <cmd_max>10</cmd_max>
            <cmd_min>-10</cmd_min>
        </plugin>
    </gazebo>

    <!-- ==================== Sensors ==================== -->

    <!-- 2D LiDAR on lidar_frame (A1 lidar: 360°, 12m range, ~5.5Hz) -->
    <gazebo reference="lidar_frame">
        <sensor name="lidar" type="gpu_lidar">
            <pose>0 0 0 0 0 0</pose>
            <topic>scan</topic>
            <gz_frame_id>lidar_frame</gz_frame_id>
            <update_rate>5.5</update_rate>
            <always_on>true</always_on>
            <visualize>false</visualize>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.15</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
        </sensor>
    </gazebo>

    <!-- IMU sensor on imu_link -->
    <gazebo reference="imu_link">
        <sensor name="imu" type="imu">
            <topic>imu</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <update_rate>50</update_rate>
            <always_on>true</always_on>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- Fixed body RGBD camera for room scanning / perception -->
    <!-- Gazebo cameras render along +x of their attached frame -->
    <gazebo reference="body_cam_link">
        <sensor name="body_rgbd_camera" type="rgbd_camera">
            <topic>camera</topic>
            <gz_frame_id>body_cam_optical_frame</gz_frame_id>
            <update_rate>15</update_rate>
            <always_on>true</always_on>
            <camera>
                <horizontal_fov>1.57</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>10.0</far>
                </clip>
                <depth_camera>
                    <clip>
                        <near>0.05</near>
                        <far>10.0</far>
                    </clip>
                </depth_camera>
            </camera>
        </sensor>
    </gazebo>

    <!-- Arm-mounted RGBD camera (for pick/place guidance, DC5) -->
    <gazebo reference="depth_cam_frame">
        <sensor name="arm_rgbd_camera" type="rgbd_camera">
            <topic>arm_camera</topic>
            <gz_frame_id>depth_cam_frame</gz_frame_id>
            <update_rate>15</update_rate>
            <always_on>true</always_on>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <depth_camera>
                    <clip>
                        <near>0.1</near>
                        <far>10.0</far>
                    </clip>
                </depth_camera>
            </camera>
        </sensor>
    </gazebo>

</robot>
